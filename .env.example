# ─── Spotify ────────────────────────────────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=flowstate
POSTGRES_PASSWORD=flowstate_dev
POSTGRES_DB=flowstate
DATABASE_URL=postgresql://flowstate:flowstate_dev@localhost:5432/flowstate

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_in_production
ENVIRONMENT=development

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

# ─── Airflow ─────────────────────────────────────────────────────────────────
AIRFLOW_SECRET_KEY=change_this_too
